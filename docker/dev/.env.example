COMPOSE_PROJECT_NAME=cv-site

# Host ports mapped to container ports.
HOST_VITE_PORT=5173
HOST_CRA_PORT=3000
HOST_PREVIEW_PORT=4173

# Optional override for host home directory.
# Set this only if HOME/USERPROFILE detection does not work on your machine.
# Windows example: HOST_HOME=C:/Users/your-user
# Linux example:   HOST_HOME=/home/your-user
# HOST_HOME=
