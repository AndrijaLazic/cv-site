# Public values exposed to frontend code
VITE_BACKEND_URL=http://localhost:3000
VITE_SITE_URL=https://gundra.dev

# Vite watch behavior (helpful in containers)
VITE_USE_POLLING=false
VITE_WATCH_POLL_INTERVAL=120

# Optional HTTPS for Vite dev server; set both VITE_* values to enable
VITE_HTTPS_CERT_PATH=./certs/localhost.pem
VITE_HTTPS_KEY_PATH=./certs/localhost-key.pem

# Deprecated fallback names (still supported)
DEV_HTTPS_CERT_PATH=
DEV_HTTPS_KEY_PATH=
